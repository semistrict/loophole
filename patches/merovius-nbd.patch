+	binary.BigEndian.PutUint32(buf[4:8], errno)
+	binary.BigEndian.PutUint64(buf[8:16], handle)
+	copy(buf[16:], data)
+
+	rw.mu.Lock()
+	rw.w.Write(buf)
+	rw.mu.Unlock()
+}
