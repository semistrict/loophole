{
	"name": "cf-demo",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "make -C .. cf-demo-assets-local && (node scripts/docker-fuse.mjs & DOCKER_HOST=unix:///tmp/docker-fuse.sock WRANGLER_DOCKER_BIN=./scripts/docker-no-proxy.mjs vite dev --port 7935; kill %1 2>/dev/null)",
		"smoke:local": "pnpm dlx tsx scripts/smoke-local.ts",
		"typecheck": "tsc --noEmit",
		"build": "make -C .. cf-demo-assets && vite build && pnpm run typecheck",
		"preview": "pnpm run build && vite preview",
		"test": "vitest run --config vitest.config.ts",
		"deploy": "pnpm run build && wrangler deploy",
		"ssh": "CONTROL_SECRET=$(grep '^CONTROL_SECRET=' .dev.vars | cut -d= -f2-) exec ../bin/loophole-darwin-arm64 ssh --url \"${CF_DEMO_URL:?Set CF_DEMO_URL to your worker URL}\" --secret \"$CONTROL_SECRET\" --volume",
		"cf-typegen": "wrangler types"
	},
	"dependencies": {
		"@base-ui/react": "^1.2.0",
		"@cloudflare/containers": "^0.1.1",
		"@cloudflare/vite-plugin": "^1.13.8",
		"@fontsource-variable/inter": "^5.2.8",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/react-devtools": "^0.7.0",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-router": "^1.132.0",
		"@tanstack/react-router-devtools": "^1.132.0",
		"@tanstack/react-router-ssr-query": "^1.131.7",
		"@tanstack/react-start": "^1.132.0",
		"@tanstack/router-plugin": "^1.132.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^0.545.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"shadcn": "^4.0.0",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@tanstack/devtools-vite": "^0.3.11",
		"@testing-library/dom": "^10.4.0",
		"@testing-library/react": "^16.2.0",
		"@types/node": "^22.19.15",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^5.0.4",
		"jsdom": "^27.0.0",
		"typescript": "^5.7.2",
		"vite": "^7.1.7",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^3.0.5",
		"wrangler": "^4.71.0"
	}
}
