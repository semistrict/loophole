FROM debian:bookworm
RUN apt-get update && apt-get install -y \
    linux-image-arm64 \
    systemd-sysv \
    && rm -rf /var/lib/apt/lists/*
# Apple Virtualization.framework uses virtio console (hvc0); Debian's
# default initramfs doesn't include the module, so systemd never sees it.
RUN echo "root:root" | chpasswd
RUN echo virtio_console >> /etc/initramfs-tools/modules && \
    echo "RESUME=none" > /etc/initramfs-tools/conf.d/noresume && \
    update-initramfs -u
